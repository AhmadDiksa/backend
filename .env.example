# Copy to .env and fill in values
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENROUTER_API_KEY=sk-or-your-key-here
GEMINI_API_KEY=AIzaSy-your-key-here
PORT=3001
FRONTEND_URL=http://localhost:3000
JWT_SECRET=generate-a-long-random-string-here

# RAG engine: "tfidf" (default, pure JS) or "langchain" (LangChain LCEL)
RAG_MODE=tfidf

# ── Restaurant Agent ───────────────────────────────────────────────
# Set AGENT_MODE=restaurant to activate restaurant CS agent with tools
AGENT_MODE=off

# Google Sheets integration (required when AGENT_MODE=restaurant)
GOOGLE_SHEETS_ID=your_spreadsheet_id_here
# Paste entire service account JSON as a single-line string:
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
